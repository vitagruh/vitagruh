# Telegram Bot Token
TELEGRAM_TOKEN=your_bot_token_here

# Интервал проверки билетов (в секундах). По умолчанию 60 секунд.
CHECK_INTERVAL=60

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
# По умолчанию INFO - пишет в консоль и файл все сообщения от INFO и выше
LOG_LEVEL=INFO

# Путь к основному лог-файлу (все логи INFO+)
LOG_FILE=logs/bot.log

# Путь к файлу ошибок (только ERROR и CRITICAL)
ERROR_LOG_FILE=logs/error.log
